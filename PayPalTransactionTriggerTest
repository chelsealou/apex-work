@IsTest
private class PayPalTransactionTriggerTest {

    // ── Shared test data helpers ─────────────────────────────────────────────

    private static Id hhRecTypeId {
        get {
            if (hhRecTypeId == null) {
                hhRecTypeId = Schema.SObjectType.Account
                    .getRecordTypeInfosByName()
                    .get('Household Account')
                    .getRecordTypeId();
            }
            return hhRecTypeId;
        }
        set;
    }

    private static Account makeAccount(String firstName, String lastName, String street) {
        return new Account(
            Name          = firstName + ' ' + lastName,
            RecordTypeId  = hhRecTypeId,
            BillingStreet = street,
            BillingCity   = 'Austin',
            BillingState  = 'TX',
            BillingPostalCode = '78701'
        );
    }

    private static Contact makeContact(Id accountId, String firstName, String lastName, String email) {
        return new Contact(
            AccountId = accountId,
            FirstName = firstName,
            LastName  = lastName,
            Email     = email
        );
    }

    private static sptc__PayPal_Transaction__c makeTx(
        String firstName, String lastName, String email,
        String street, Decimal amount
    ) {
        return new sptc__PayPal_Transaction__c(
            sptc__First_Name__c              = firstName,
            sptc__Last_Name__c               = lastName,
            sptc__Email__c                   = email,
            sptc__Billing_Address_Street__c  = street,
            sptc__Billing_Address_City__c    = 'Austin',
            sptc__Billing_Address_StateCode__c = 'TX',
            sptc__Billing_Address_PostalCode__c = '78701',
            sptc__Transaction_Amount__c      = amount,
            sptc__Transaction_Date__c        = Date.today(),
            sptc__Transaction_ID__c          = 'TXN-' + String.valueOf(Math.random()).right(6)
        );
    }

    // ── Test 1: Email match → existing Account and Contact reused ────────────
    @IsTest
    static void testEmailMatch_usesExistingAccount() {
        Account acct = makeAccount('Jane', 'Smith', '100 Main St');
        insert acct;
        Contact con = makeContact(acct.Id, 'Jane', 'Smith', 'jane.smith@example.com');
        insert con;

        Test.startTest();
        sptc__PayPal_Transaction__c tx = makeTx('Jane', 'Smith', 'jane.smith@example.com', '100 Main St', 50);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c, sptc__Contact__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertEquals(acct.Id, result.sptc__Account__c, 'Account should match via email');

        List<Opportunity> opps = [SELECT AccountId FROM Opportunity WHERE AccountId = :acct.Id];
        System.assertEquals(1, opps.size(), 'One Opportunity should be created');

        // No new Contact should have been created on this Account beyond the original
        List<Contact> contacts = [SELECT Id FROM Contact WHERE AccountId = :acct.Id];
        System.assertEquals(1, contacts.size(), 'No new Contact should be created for an email match');
    }

    // ── Test 2: Name + address match, same first name → no new Contact ────────
    @IsTest
    static void testNameAddressMatch_sameFirstName_noNewContact() {
        Account acct = makeAccount('Bob', 'Jones', '200 Oak Ave');
        insert acct;
        Contact con = makeContact(acct.Id, 'Bob', 'Jones', 'bob.jones@example.com');
        insert con;

        Test.startTest();
        // Different email so email lookup misses; same first name so no mismatch
        sptc__PayPal_Transaction__c tx = makeTx('Bob', 'Jones', 'different@example.com', '200 Oak Ave', 75);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertEquals(acct.Id, result.sptc__Account__c, 'Account should match via name+address');

        List<Contact> contacts = [SELECT Id FROM Contact WHERE AccountId = :acct.Id];
        System.assertEquals(1, contacts.size(), 'No new Contact should be created when first name matches');

        List<OpportunityContactRole> ocrs = [SELECT Id FROM OpportunityContactRole WHERE Opportunity.AccountId = :acct.Id];
        System.assertEquals(0, ocrs.size(), 'No OCR should be created when first name matches');
    }

    // ── Test 3: Name + address match, DIFFERENT first name → new Contact + OCR
    @IsTest
    static void testNameAddressMatch_differentFirstName_createsContactAndOCR() {
        Account acct = makeAccount('Alice', 'Williams', '300 Pine Rd');
        insert acct;
        Contact existing = makeContact(acct.Id, 'Alice', 'Williams', 'alice.williams@example.com');
        insert existing;

        Test.startTest();
        // Bob Williams at the same address — different first name
        sptc__PayPal_Transaction__c tx = makeTx('Bob', 'Williams', 'bob.williams@example.com', '300 Pine Rd', 100);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c, sptc__Contact__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertEquals(acct.Id, result.sptc__Account__c, 'Account should match via name+address');

        // A new Contact should have been created
        List<Contact> contacts = [SELECT Id, FirstName, Email FROM Contact WHERE AccountId = :acct.Id ORDER BY CreatedDate];
        System.assertEquals(2, contacts.size(), 'A new Contact should be created for the different first name');

        Contact newCon = contacts[1];
        System.assertEquals('Bob', newCon.FirstName, 'New Contact first name should come from the transaction');
        System.assertEquals('bob.williams@example.com', newCon.Email, 'New Contact email should come from the transaction');

        // Transaction should point to the new Contact, not the original
        System.assertEquals(newCon.Id, result.sptc__Contact__c, 'Transaction Contact should be the newly created Contact');

        // Original Account primary Contact should be unchanged
        Account acctReloaded = [SELECT npe01__One2OneContact__c FROM Account WHERE Id = :acct.Id];
        System.assertNotEquals(newCon.Id, acctReloaded.npe01__One2OneContact__c,
            'Account primary Contact should NOT be changed to the new Contact');

        // OCR should exist with IsPrimary = true
        List<OpportunityContactRole> ocrs = [
            SELECT ContactId, IsPrimary, Role
            FROM   OpportunityContactRole
            WHERE  Opportunity.AccountId = :acct.Id
        ];
        System.assertEquals(1, ocrs.size(), 'One OCR should be created');
        System.assertEquals(newCon.Id, ocrs[0].ContactId, 'OCR should reference the new Contact');
        System.assertEquals(true, ocrs[0].IsPrimary, 'OCR should be marked primary');
    }

    // ── Test 4: No match at all → new Account created ─────────────────────────
    @IsTest
    static void testNoMatch_createsNewAccount() {
        Test.startTest();
        sptc__PayPal_Transaction__c tx = makeTx('Carol', 'Taylor', 'carol.taylor@example.com', '400 Elm St', 200);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertNotEquals(null, result.sptc__Account__c, 'A new Account should have been created');

        Account newAcct = [SELECT Name, BillingStreet, RecordTypeId FROM Account WHERE Id = :result.sptc__Account__c];
        System.assertEquals('Carol Taylor', newAcct.Name, 'New Account name should combine first and last name');
        System.assertEquals('400 Elm St', newAcct.BillingStreet, 'New Account should have the billing street from the transaction');
        System.assertEquals(hhRecTypeId, newAcct.RecordTypeId, 'New Account should be Household type');

        List<Opportunity> opps = [SELECT Amount FROM Opportunity WHERE AccountId = :newAcct.Id];
        System.assertEquals(1, opps.size(), 'One Opportunity should be created');
        System.assertEquals(200, opps[0].Amount, 'Opportunity amount should match the transaction amount');
    }

    // ── Test 5: Opportunity fields are populated correctly ────────────────────
    @IsTest
    static void testOpportunityFieldsPopulated() {
        Test.startTest();
        sptc__PayPal_Transaction__c tx = new sptc__PayPal_Transaction__c(
            sptc__First_Name__c              = 'Dana',
            sptc__Last_Name__c               = 'Brown',
            sptc__Email__c                   = 'dana.brown@example.com',
            sptc__Billing_Address_Street__c  = '500 Maple Dr',
            sptc__Billing_Address_City__c    = 'Dallas',
            sptc__Billing_Address_StateCode__c = 'TX',
            sptc__Billing_Address_PostalCode__c = '75201',
            sptc__Transaction_Amount__c      = 123.45,
            sptc__Transaction_Date__c        = Date.newInstance(2026, 1, 15),
            sptc__Transaction_ID__c          = 'TXN-ABC123'
        );
        insert tx;
        Test.stopTest();

        Opportunity opp = [
            SELECT Name, StageName, Amount, CloseDate, Transaction_Reference_ID__c
            FROM   Opportunity
            WHERE  Transaction_Reference_ID__c = 'TXN-ABC123'
        ];
        System.assertEquals('PayPal Transaction - TXN-ABC123', opp.Name);
        System.assertEquals('Closed Won', opp.StageName);
        System.assertEquals(123.45, opp.Amount);
        System.assertEquals(Date.newInstance(2026, 1, 15), opp.CloseDate);
    }

    // ── Test 6: Blank transaction date falls back to today ────────────────────
    @IsTest
    static void testBlankTransactionDate_fallsBackToToday() {
        Test.startTest();
        sptc__PayPal_Transaction__c tx = new sptc__PayPal_Transaction__c(
            sptc__First_Name__c              = 'Eve',
            sptc__Last_Name__c               = 'Garcia',
            sptc__Email__c                   = 'eve.garcia@example.com',
            sptc__Billing_Address_Street__c  = '600 Cedar Ln',
            sptc__Billing_Address_StateCode__c = 'TX',
            sptc__Billing_Address_PostalCode__c = '78702',
            sptc__Transaction_Amount__c      = 50,
            sptc__Transaction_Date__c        = null
        );
        insert tx;
        Test.stopTest();

        Opportunity opp = [SELECT CloseDate FROM Opportunity WHERE Account.Name = 'Eve Garcia'];
        System.assertEquals(Date.today(), opp.CloseDate, 'CloseDate should default to today when transaction date is blank');
    }

    // ── Test 7: Bulk — 200 transactions, mix of match scenarios ──────────────
    @IsTest
    static void testBulk_200Transactions() {
        // One existing Account/Contact to match against for half the records
        Account acct = makeAccount('Frank', 'Martin', '700 Birch Blvd');
        insert acct;
        Contact con = makeContact(acct.Id, 'Frank', 'Martin', 'frank.martin@example.com');
        insert con;

        List<sptc__PayPal_Transaction__c> txList = new List<sptc__PayPal_Transaction__c>();
        for (Integer i = 0; i < 200; i++) {
            if (Math.mod(i, 2) == 0) {
                // Even rows: email match to existing Account
                txList.add(makeTx('Frank', 'Martin', 'frank.martin@example.com', '700 Birch Blvd', 10));
            } else {
                // Odd rows: brand-new donor
                txList.add(makeTx('New', 'Donor' + i, 'donor' + i + '@example.com', i + ' Test St', 20));
            }
        }

        Test.startTest();
        insert txList;
        Test.stopTest();

        // 100 existing-account matches + 100 new accounts = 101 accounts total
        List<Account> allAccounts = [SELECT Id FROM Account];
        System.assertEquals(101, allAccounts.size(), 'Should be 101 Accounts total (1 existing + 100 new)');

        // 200 Opportunities should have been created
        List<Opportunity> allOpps = [SELECT Id FROM Opportunity];
        System.assertEquals(200, allOpps.size(), 'Should be 200 Opportunities created');
    }
}
