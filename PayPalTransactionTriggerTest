    // ── Test 13: Bulk — 200 transactions, mix of match scenarios ─────────────
    @IsTest
    static void testBulk_200Transactions() {
        Account acct = makeAccount('Frank Martin', '700 Birch Blvd');
        insert acct;
        Contact con = makeContact(acct.Id, 'Frank', 'Martin', 'frank.martin@example.com');
        insert con;

        List<sptc__PayPal_Transaction__c> txList = new List<sptc__PayPal_Transaction__c>();
        for (Integer i = 0; i < 200; i++) {
            if (Math.mod(i, 2) == 0) {
                // Even rows: email match to existing Account
                txList.add(makeTx('Frank', 'Martin', 'frank.martin@example.com', '700 Birch Blvd', 10));
            } else {
                // Odd rows: brand-new donor
                txList.add(makeTx('New', 'Donor' + i, 'donor' + i + '@example.com', i + ' Test St', 20));
            }
        }

        Test.startTest();
        insert txList;
        Test.stopTest();

        // 100 existing-account matches + 100 new accounts = 101 accounts total
        List<Account> allAccounts = [SELECT Id FROM Account];
        System.assertEquals(101, allAccounts.size(), 'Should be 101 Accounts total (1 existing + 100 new)');

        List<Opportunity> allOpps = [SELECT Id FROM Opportunity];
        System.assertEquals(200, allOpps.size(), 'Should be 200 Opportunities created');
    }
