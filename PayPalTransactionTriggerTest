@IsTest
private class PayPalTransactionTriggerTest {

    // ── Shared test data helpers ─────────────────────────────────────────────

    private static Id hhRecTypeId {
        get {
            if (hhRecTypeId == null) {
                hhRecTypeId = Schema.SObjectType.Account
                    .getRecordTypeInfosByName()
                    .get('Household Account')
                    .getRecordTypeId();
            }
            return hhRecTypeId;
        }
        set;
    }

    private static Account makeAccount(String name, String street) {
        return new Account(
            Name              = name,
            RecordTypeId      = hhRecTypeId,
            BillingStreet     = street,
            BillingCity       = 'Austin',
            BillingState      = 'TX',
            BillingPostalCode = '78701'
        );
    }

    private static Contact makeContact(Id accountId, String firstName, String lastName, String email) {
        return new Contact(
            AccountId = accountId,
            FirstName = firstName,
            LastName  = lastName,
            Email     = email
        );
    }

    private static sptc__PayPal_Transaction__c makeTx(
        String firstName, String lastName, String email,
        String street, Decimal amount
    ) {
        return new sptc__PayPal_Transaction__c(
            sptc__First_Name__c               = firstName,
            sptc__Last_Name__c                = lastName,
            sptc__Email__c                    = email,
            sptc__Billing_Address_Street__c   = street,
            sptc__Billing_Address_City__c     = 'Austin',
            sptc__Billing_Address_StateCode__c  = 'TX',
            sptc__Billing_Address_PostalCode__c = '78701',
            sptc__Transaction_Amount__c       = amount,
            sptc__Transaction_Date__c         = Date.today(),
            sptc__Transaction_ID__c           = 'TXN-' + String.valueOf(Math.random()).right(6)
        );
    }

    // Removes any OCR that NPSP may have auto-inserted as primary so that
    // our trigger's IsPrimary OCR can be asserted cleanly.
    private static void clearNpspOcrs(Id oppId) {
        List<OpportunityContactRole> existing = [
            SELECT Id FROM OpportunityContactRole
            WHERE OpportunityId = :oppId AND IsPrimary = true
        ];
        if (!existing.isEmpty()) {
            delete existing;
        }
    }

    // ── Test 1: Email match → existing Account reused, no new Contact ─────────
    @IsTest
    static void testEmailMatch_usesExistingAccount() {
        Account acct = makeAccount('Jane Smith', '100 Main St');
        insert acct;
        Contact con = makeContact(acct.Id, 'Jane', 'Smith', 'jane.smith@example.com');
        insert con;

        Test.startTest();
        sptc__PayPal_Transaction__c tx = makeTx('Jane', 'Smith', 'jane.smith@example.com', '100 Main St', 50);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertEquals(acct.Id, result.sptc__Account__c, 'Account should match via email');

        List<Opportunity> opps = [SELECT Id FROM Opportunity WHERE AccountId = :acct.Id];
        System.assertEquals(1, opps.size(), 'One Opportunity should be created');

        List<Contact> contacts = [SELECT Id FROM Contact WHERE AccountId = :acct.Id];
        System.assertEquals(1, contacts.size(), 'No new Contact should be created for an email match');
    }

    // ── Test 2: Name+address match, same first name → no new Contact or OCR ───
    @IsTest
    static void testNameAddressMatch_sameFirstName_noNewContact() {
        Account acct = makeAccount('Bob Jones', '200 Oak Ave');
        insert acct;
        Contact con = makeContact(acct.Id, 'Bob', 'Jones', 'bob.jones@example.com');
        insert con;

        Test.startTest();
        // Different email so email lookup misses; same first name so no mismatch
        sptc__PayPal_Transaction__c tx = makeTx('Bob', 'Jones', 'different@example.com', '200 Oak Ave', 75);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertEquals(acct.Id, result.sptc__Account__c, 'Account should match via name+address');

        List<Contact> contacts = [SELECT Id FROM Contact WHERE AccountId = :acct.Id];
        System.assertEquals(1, contacts.size(), 'No new Contact should be created when first name matches');

        List<OpportunityContactRole> ocrs = [
            SELECT Id FROM OpportunityContactRole
            WHERE Opportunity.AccountId = :acct.Id AND IsPrimary = true
        ];
        System.assertEquals(0, ocrs.size(), 'No primary OCR should be created when first name matches');
    }

    // ── Test 3: Name+address match, DIFFERENT first name → new Contact + OCR ──
    @IsTest
    static void testNameAddressMatch_differentFirstName_createsContactAndOCR() {
        Account acct = makeAccount('Alice Williams', '300 Pine Rd');
        insert acct;
        Contact existing = makeContact(acct.Id, 'Alice', 'Williams', 'alice.williams@example.com');
        insert existing;

        Test.startTest();
        // Bob Williams at the same address — different first name
        sptc__PayPal_Transaction__c tx = makeTx('Bob', 'Williams', 'bob.williams@example.com', '300 Pine Rd', 100);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c, sptc__Contact__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertEquals(acct.Id, result.sptc__Account__c, 'Account should match via name+address');

        // New Contact should have been created with the transaction's data
        Contact newCon = [
            SELECT Id, FirstName, Email
            FROM   Contact
            WHERE  AccountId = :acct.Id AND FirstName = 'Bob'
        ];
        System.assertNotEquals(null, newCon, 'A new Contact should exist for the different first name');
        System.assertEquals('bob.williams@example.com', newCon.Email, 'New Contact email should come from the transaction');

        // Transaction should point to the new Contact, not the original
        System.assertEquals(newCon.Id, result.sptc__Contact__c, 'Transaction Contact should be the new Contact');

        // Account's primary Contact should NOT have been changed by the trigger
        Account acctReloaded = [SELECT npe01__One2OneContact__c FROM Account WHERE Id = :acct.Id];
        System.assertNotEquals(newCon.Id, acctReloaded.npe01__One2OneContact__c,
            'Trigger should not change the Account primary Contact to the new Contact');

        // Our trigger's OCR should exist with IsPrimary = true for the new Contact.
        // If NPSP also auto-inserted a primary OCR we clear it first so the
        // assertion is isolated to what the trigger created.
        List<Opportunity> opps = [SELECT Id FROM Opportunity WHERE AccountId = :acct.Id];
        System.assertEquals(1, opps.size(), 'One Opportunity should be created');

        List<OpportunityContactRole> ocrs = [
            SELECT ContactId, IsPrimary
            FROM   OpportunityContactRole
            WHERE  OpportunityId = :opps[0].Id AND ContactId = :newCon.Id
        ];
        System.assertEquals(1, ocrs.size(), 'OCR for the new Contact should exist');
        System.assertEquals(true, ocrs[0].IsPrimary, 'OCR should be marked primary');
    }

    // ── Test 4: No match at all → new Household Account + Contact created ─────
    @IsTest
    static void testNoMatch_createsNewAccount() {
        Test.startTest();
        sptc__PayPal_Transaction__c tx = makeTx('Carol', 'Taylor', 'carol.taylor@example.com', '400 Elm St', 200);
        insert tx;
        Test.stopTest();

        sptc__PayPal_Transaction__c result = [
            SELECT sptc__Account__c, sptc__Contact__c FROM sptc__PayPal_Transaction__c WHERE Id = :tx.Id
        ];
        System.assertNotEquals(null, result.sptc__Account__c, 'A new Account should have been created');

        Account newAcct = [SELECT Name, BillingStreet, RecordTypeId FROM Account WHERE Id = :result.sptc__Account__c];
        System.assertEquals('Carol Taylor', newAcct.Name, 'Account name should be first + last');
        System.assertEquals('400 Elm St', newAcct.BillingStreet, 'Account street should come from the transaction');
        System.assertEquals(hhRecTypeId, newAcct.RecordTypeId, 'Account should be Household type');

        List<Opportunity> opps = [SELECT Amount FROM Opportunity WHERE AccountId = :newAcct.Id];
        System.assertEquals(1, opps.size(), 'One Opportunity should be created');
        System.assertEquals(200, opps[0].Amount, 'Opportunity amount should match the transaction amount');

        // A Contact should have been created on the new Account
        Contact con = [SELECT FirstName, LastName, Email FROM Contact WHERE AccountId = :newAcct.Id];
        System.assertEquals('Carol', con.FirstName, 'Contact first name should come from the transaction');
        System.assertEquals('Taylor', con.LastName, 'Contact last name should come from the transaction');
        System.assertEquals('carol.taylor@example.com', con.Email, 'Contact email should come from the transaction');
        System.assertEquals(con.Id, result.sptc__Contact__c, 'Transaction Contact lookup should point to the new Contact');
    }

